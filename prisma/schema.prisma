// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Merchant model for multi-tenant credit management
model Merchant {
  id       String @id @default(cuid())
  email    String @unique
  password String // Will be hashed
  name     String
  currency String @default("TND") // TND, EUR, USD, etc.

  // Business information
  businessName    String?
  businessAddress String?
  phone          String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clients           Client[]
  credits           Credit[]
  payments          Payment[]
  paymentAllocations PaymentAllocation[]

  // Indexes for performance
  @@index([email])
  @@map("merchants")
}

// Client model for customer management
model Client {
  id        String @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  address   String?

  // Business information
  businessName String?
  taxId        String?

  // Credit settings
  creditLimit     Decimal? @db.Decimal(10, 2)
  paymentTermDays Int      @default(30)

  // Multi-tenant relationship
  merchantId String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  merchant           Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  credits            Credit[]
  payments           Payment[]
  paymentAllocations PaymentAllocation[]

  // Indexes for multi-tenant queries
  @@index([merchantId])
  @@index([firstName, lastName])
  @@index([email])
  @@map("clients")
}

// Credit model for managing credit transactions
model Credit {
  id              String       @id @default(cuid())
  label           String
  totalAmount     Decimal      @db.Decimal(10, 2)
  remainingAmount Decimal      @db.Decimal(10, 2)
  dueDate         DateTime?
  status          CreditStatus // Auto-calculated based on remainingAmount and dueDate
  description     String?

  // Multi-tenant relationships
  merchantId String
  clientId   String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  merchant           Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  paymentAllocations PaymentAllocation[]

  // Indexes for multi-tenant queries and performance
  @@index([merchantId])
  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([merchantId, clientId])
  @@index([merchantId, status])
  @@map("credits")
}

// Payment model for tracking payments
model Payment {
  id     String  @id @default(cuid())
  amount Decimal @db.Decimal(10, 2)
  note   String?

  // Payment details
  method      PaymentMethod @default(CASH)
  reference   String? // Bank reference, check number, etc.
  paymentDate DateTime      @default(now())

  // Multi-tenant relationships
  merchantId String
  clientId   String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  merchant           Merchant            @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  paymentAllocations PaymentAllocation[]

  // Indexes for multi-tenant queries and performance
  @@index([merchantId])
  @@index([clientId])
  @@index([paymentDate])
  @@index([merchantId, clientId])
  @@index([merchantId, paymentDate])
  @@map("payments")
}

// PaymentAllocation model for FIFO payment distribution
model PaymentAllocation {
  id              String  @id @default(cuid())
  amount          Decimal @db.Decimal(10, 2)
  allocatedAmount Decimal @db.Decimal(10, 2)

  // Multi-tenant relationships
  merchantId String
  clientId   String
  paymentId  String
  creditId   String

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payment  Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  credit   Credit   @relation(fields: [creditId], references: [id], onDelete: Cascade)

  // Indexes for FIFO queries and performance
  @@index([merchantId])
  @@index([clientId])
  @@index([paymentId])
  @@index([creditId])
  @@index([merchantId, clientId])
  @@index([paymentId, creditId])
  @@map("payment_allocations")
}

// Enums
enum CreditStatus {
  OPEN    // OUVERT - Credit has remaining amount > 0
  PAID    // PAYÉ - Credit is fully paid (remainingAmount = 0)
  OVERDUE // EN RETARD - Credit is past due date with remaining amount > 0
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CARD
  MOBILE_PAYMENT
  OTHER
}